<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom">
  <div class="container">
    <div class="navbar-nav me-auto">
      <%= link_to t("nav.home"), root_path, class: "nav-item nav-link" %>
      <% if current_user %>
        <%= link_to t("nav.repositories"), repositories_path, class: "nav-item nav-link" %>
      <% end %>
    </div>
    
    <div class="navbar-nav">
      <% if current_user %>
        <span class="nav-item nav-link"><%= t("welcome") %> <%= current_user.nickname %></span>
        <%= link_to t("auth.logout"), logout_path, class: "nav-item nav-link", data: { turbo_method: :delete } %>
      <% else %>
        <%= button_to auth_request_path, method: :post, data: { turbo: false }, class: "nav-item nav-link btn btn-link" do %>
          <i class="bi bi-github me-1"></i> <%= t("auth.login") %>
        <% end %>
      <% end %>
    </div>
  </div>
</nav>
