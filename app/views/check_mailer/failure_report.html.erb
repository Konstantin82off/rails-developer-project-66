<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type">
</head>
<body>
  <h1>Check failed for <%= @repository.full_name %></h1>
  
  <p>Hello <%= @user.nickname %>,</p>
  
  <p>The check for repository <strong><%= @repository.full_name %></strong> has completed with errors.</p>
  
  <h3>Check details:</h3>
  <ul>
    <li><strong>Commit ID:</strong> <%= @check.commit_id %></li>
    <li><strong>Status:</strong> <%= @check.passed ? "Passed" : "Failed" %></li>
    <li><strong>Created at:</strong> <%= @check.created_at %></li>
  </ul>
  
  <h3>Output:</h3>
  <pre class="email-output"><%= @check.output %></pre>
  
  <p>
    <%= link_to "View check details", repository_check_url(@repository, @check) %>
  </p>
  
  <p>Best regards,<br>GitHub Quality Analyzer</p>
</body>
</html>
