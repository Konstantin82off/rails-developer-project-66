<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-12">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h1 class="display-6 fw-semibold mb-4"><%= @repository.full_name %></h1>

          <div class="mb-4">
            <%= button_to t(".run_check"), repository_checks_path(@repository), method: :post, class: "btn btn-primary", data: { turbo: false } %>
          </div>

          <div class="mb-4">
            <p><strong><%= t(".name") %>:</strong> <%= @repository.full_name %></p>
            <p><strong><%= t(".language") %>:</strong> <%= @repository.language %></p>
            <p><strong><%= t(".created_at") %>:</strong> <%= @repository.created_at.strftime("%d %B %Y, %H:%M") if @repository.created_at %></p>
            <p><strong><%= t(".updated_at") %>:</strong> <%= @repository.updated_at.strftime("%d %B %Y, %H:%M") if @repository.updated_at %></p>
          </div>

          <% if @repository.checks.any? %>
            <table class="table table-striped">
              <thead>
                <tr>
                  <th></th>
                  <th><%= t(".status") %></th>
                  <th><%= t(".commit_id") %></th>
                  <th><%= t(".passed") %></th>
                  <th><%= t(".created_at") %></th>
                </tr>
              </thead>
              <tbody>
                <% @repository.checks.order(created_at: :desc).each do |check| %>
                  <tr>
                    <td><%= link_to check.id, repository_check_path(@repository, check) %></td>
                    <td><span class="badge bg-<%= check_state_badge(check.aasm_state) %>"><%= check.aasm_state == "finished" ? t(".finished") : check.aasm_state %></span></td>
                    <td>
                      <% if check.commit_id && check.commit_id != "pending" %>
                        <%= link_to check.commit_id.first(8), "https://github.com/#{@repository.full_name}/commit/#{check.commit_id}", target: "_blank" %>
                      <% else %>
                        <%= check.commit_id&.first(8) %>...
                      <% end %>
                    </td>
                    <td><%= check.passed.nil? ? t(".pending") : (check.passed ? t(".true") : t(".false")) %></td>
                    <td><%= check.created_at.strftime("%d %b, %H:%M") %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <p class="text-center"><%= t(".no_checks") %> <%= button_to t(".run_first_check"), repository_checks_path(@repository), method: :post, data: { turbo: false } %></p>
          <% end %>
          
          <div class="mt-4">
            <%= link_to t(".back"), repositories_path, class: "btn btn-secondary" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
