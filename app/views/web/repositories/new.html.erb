<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-12">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <div class="mb-4">
            <label class="form-label">
              Github
              <span class="text-muted" style="cursor: help;" data-bs-toggle="tooltip" data-bs-placement="right" title="<%= t(".tooltip") %>">*</span>
            </label>

            <% if @github_repos.any? %>
              <%= form_tag repositories_path, method: :post, id: "new-repository-form" do %>
                <div class="mb-3">
                  <%= select_tag "repository[github_id]",
                      options_for_select(
                        @github_repos.select do |r|
                          r.language&.downcase == "ruby" ||
                          r.language&.downcase == "javascript"
                        end.map { |r| ["#{r.full_name} (#{r.language})", r.id] }
                      ),
                      prompt: t(".select_repository"),
                      class: "form-select",
                      id: "repository_github_id" %>
                </div>

                <%= submit_tag t(".add_button"), class: "btn btn-success" %>
              <% end %>
            <% else %>
              <p class="text-muted"><%= t(".no_ruby_repos") %></p>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
