<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1><%= @repository.full_name %></h1>
    <%= link_to "Run Check", repository_checks_path(@repository), method: :post, class: "btn btn-primary" %>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <h5 class="card-title">Repository Info</h5>
      <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9"><%= @repository.full_name %></dd>
        
        <dt class="col-sm-3">Language</dt>
        <dd class="col-sm-9"><%= @repository.language %></dd>
        
        <dt class="col-sm-3">Created at</dt>
        <dd class="col-sm-9"><%= @repository.created_at.strftime("%B %d, %Y %H:%M") if @repository.created_at %></dd>
        
        <dt class="col-sm-3">Updated at</dt>
        <dd class="col-sm-9"><%= @repository.updated_at.strftime("%B %d, %Y %H:%M") if @repository.updated_at %></dd>
      </dl>
    </div>
  </div>

  <h3>Checks</h3>
  <% if @repository.checks.any? %>
    <table class="table table-bordered">
      <thead>
        <tr>
          <th>ID</th>
          <th>Commit ID</th>
          <th>State</th>
          <th>Passed</th>
          <th>Created At</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% @repository.checks.order(created_at: :desc).each do |check| %>
          <tr>
            <td><%= check.id %></td>
            <td><%= check.commit_id&.first(8) %>...</td>
            <td><span class="badge bg-<%= check_state_badge(check.aasm_state) %>"><%= check.aasm_state %></span></td>
            <td><%= check.passed.nil? ? "Pending" : check.passed %></td>
            <td><%= check.created_at.strftime("%d %b %H:%M") %></td>
            <td><%= link_to "View", repository_check_path(@repository, check) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No checks yet. <%= link_to "Run first check", repository_checks_path(@repository), method: :post %>.</p>
  <% end %>
  
  <%= link_to "Back to repositories", repositories_path, class: "btn btn-secondary mt-3" %>
</div>
