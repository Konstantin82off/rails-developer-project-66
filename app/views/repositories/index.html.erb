<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Repositories</h1>
    <%= link_to "New", new_repository_path, class: "btn btn-success" %>
  </div>

  <% if @repositories.any? %>
    <table class="table table-bordered">
      <thead>
        <tr>
          <th>Name</th>
          <th>Language</th>
          <th>Last check passed</th>
        </tr>
      </thead>
      <tbody>
        <% @repositories.each do |repo| %>
          <tr>
            <td><%= link_to repo.full_name, repository_path(repo) %></td>
            <td><%= repo.language %></td>
            <td>
              <% if repo.checks.any? %>
                <%= repo.checks.last.passed ? "true" : "false" %>
              <% else %>
                No checks yet
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p>No repositories added yet.</p>
  <% end %>
</div>
