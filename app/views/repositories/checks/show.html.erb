<% if @check.aasm_state == "cloning" || @check.aasm_state == "checking" %>
  <meta http-equiv="refresh" content="3">
<% end %>

<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Check #<%= @check.id %></h1>
    <%= link_to "Back to repository", repository_path(@repository), class: "btn btn-secondary" %>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <dl class="row">
        <dt class="col-sm-3">Repository</dt>
        <dd class="col-sm-9"><%= @repository.full_name %></dd>
        
        <dt class="col-sm-3">Commit ID</dt>
        <dd class="col-sm-9"><%= @check.commit_id %></dd>
        
        <dt class="col-sm-3">State</dt>
        <dd class="col-sm-9"><span class="badge bg-<%= check_state_badge(@check.aasm_state) %>"><%= @check.aasm_state %></span></dd>
        
        <dt class="col-sm-3">Passed</dt>
        <dd class="col-sm-9"><%= @check.passed.nil? ? "Pending" : @check.passed %></dd>
        
        <dt class="col-sm-3">Created at</dt>
        <dd class="col-sm-9"><%= @check.created_at.strftime("%B %d, %Y %H:%M") %></dd>
        
        <% if @check.updated_at != @check.created_at %>
          <dt class="col-sm-3">Updated at</dt>
          <dd class="col-sm-9"><%= @check.updated_at.strftime("%B %d, %Y %H:%M") %></dd>
        <% end %>
      </dl>
    </div>
  </div>

  <% if @check.output.present? %>
    <h3>Output</h3>
    <pre class="bg-light p-3 rounded"><%= @check.output %></pre>
  <% end %>
  
  <% if @check.aasm_state == "finished" && @check.passed == false %>
    <div class="alert alert-warning mt-3">
      <strong>Warning!</strong> Rubocop found offenses in this repository.
    </div>
  <% elsif @check.aasm_state == "finished" && @check.passed == true %>
    <div class="alert alert-success mt-3">
      <strong>Success!</strong> No offenses detected by Rubocop.
    </div>
  <% elsif @check.aasm_state == "failed" %>
    <div class="alert alert-danger mt-3">
      <strong>Error!</strong> The check failed to complete. Please try again.
    </div>
  <% end %>
</div>
