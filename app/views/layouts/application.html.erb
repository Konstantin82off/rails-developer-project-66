<!DOCTYPE html>
<html>
  <head>
    <title><%= t("app_name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-light">
      <div class="container">
        <%= link_to t("app_name"), root_path, class: "navbar-brand" %>
        
        <div class="navbar-nav ms-auto">
          <% if current_user %>
            <%= link_to t("repositories.index.title"), repositories_path, class: "nav-item nav-link" %>
            <span class="nav-item nav-link"><%= t("welcome") %> <%= current_user.nickname %></span>
            <%= link_to t("auth.logout"), logout_path, class: "nav-item nav-link", data: { turbo_method: :delete } %>
          <% else %>
            <a href="/auth/github" class="nav-item nav-link btn btn-primary">
              <i class="bi bi-github me-1"></i> <%= t("auth.login") %>
            </a>
          <% end %>
        </div>
      </div>
    </nav>

    <div class="container mt-4">
      <%= render "shared/flash" %>
      <%= yield %>
    </div>
  </body>
</html>
